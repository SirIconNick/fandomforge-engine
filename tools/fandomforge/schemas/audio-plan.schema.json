{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fandomforge.dev/schemas/audio-plan.schema.json",
  "title": "AudioPlan",
  "description": "Full audio mix plan: layers, per-layer gain, ducking curves, SFX impacts, loudness targets. Produced by audio-producer, consumed by QA gate and NLE exporters.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_slug",
    "target_lufs",
    "true_peak_ceiling_dbtp",
    "layers"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "project_slug": {"type": "string", "minLength": 1},
    "target_lufs": {"type": "number", "minimum": -30, "maximum": -8},
    "true_peak_ceiling_dbtp": {"type": "number", "minimum": -6, "maximum": 0},
    "song_gain_db": {"type": "number", "minimum": -24, "maximum": 6},
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/Layer"}
    },
    "duck_events": {
      "type": "array",
      "items": {"$ref": "#/$defs/DuckEvent"}
    },
    "impacts": {
      "description": "SFX impacts synced to drops/downbeats.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["at_sec", "kind"],
        "properties": {
          "at_sec": {"type": "number", "minimum": 0},
          "kind": {"type": "string", "enum": ["impact", "riser", "whoosh", "sub_boom", "tail", "reverse_cymbal"]},
          "gain_db": {"type": "number", "minimum": -24, "maximum": 12},
          "file": {"type": "string"}
        }
      }
    },
    "generated_at": {"type": "string", "format": "date-time"},
    "generator": {"type": "string"}
  },
  "$defs": {
    "Layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role", "gain_db"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "role": {
          "type": "string",
          "enum": ["music", "dialogue", "sfx", "ambient", "riser", "impact", "foley", "voiceover"]
        },
        "gain_db": {"type": "number", "minimum": -30, "maximum": 12},
        "file": {"type": "string"},
        "pan": {"type": "number", "minimum": -1, "maximum": 1},
        "eq_preset": {"type": "string"},
        "reverb_preset": {"type": "string"}
      }
    },
    "DuckEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_sec", "to_sec", "target_layer", "duck_db"],
      "properties": {
        "from_sec": {"type": "number", "minimum": 0},
        "to_sec": {"type": "number", "minimum": 0},
        "target_layer": {"type": "string", "minLength": 1},
        "duck_db": {"type": "number", "minimum": -30, "maximum": 0},
        "attack_ms": {"type": "number", "minimum": 0},
        "release_ms": {"type": "number", "minimum": 0}
      }
    }
  }
}
