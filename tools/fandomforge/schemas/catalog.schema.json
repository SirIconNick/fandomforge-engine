{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fandomforge.dev/schemas/catalog.schema.json",
  "title": "ClipCatalog",
  "description": "File-backed clip catalog produced by fandomforge.catalog.Catalog.save().",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "updated_at", "clips"],
  "properties": {
    "version": {"type": "integer", "const": 1},
    "updated_at": {"type": "string", "format": "date-time"},
    "clips": {
      "type": "array",
      "items": {"$ref": "#/$defs/Clip"}
    }
  },
  "$defs": {
    "Clip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source_title",
        "source_type",
        "fandom",
        "timestamp",
        "duration_sec",
        "description"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "source_title": {"type": "string", "minLength": 1},
        "source_type": {
          "type": "string",
          "enum": ["movie", "tv", "anime", "game", "other"]
        },
        "fandom": {"type": "string", "minLength": 1},
        "timestamp": {
          "type": "string",
          "pattern": "^[0-9]{1,3}:[0-5][0-9]:[0-5][0-9](\\.[0-9]+)?$"
        },
        "duration_sec": {"type": "number", "exclusiveMinimum": 0},
        "description": {"type": "string"},
        "mood_tags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "framing": {
          "type": "string",
          "enum": ["", "ECU", "CU", "MCU", "medium", "MS", "MWS", "wide", "WS", "EWS", "insert", "OTS", "POV"]
        },
        "motion": {"type": "string"},
        "color_notes": {"type": "string"},
        "notes": {"type": "string"},
        "created_at": {"type": "string"},
        "source_id": {
          "description": "Optional stable source identifier (blake3 hash or CAS key).",
          "type": "string"
        },
        "characters": {
          "description": "Optional list of character names confidently detected in the shot.",
          "type": "array",
          "items": {"type": "string"}
        },
        "scene_number": {"type": "integer", "minimum": 0}
      }
    }
  }
}
