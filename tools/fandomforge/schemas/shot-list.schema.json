{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fandomforge.dev/schemas/shot-list.schema.json",
  "title": "ShotList",
  "description": "The authoritative shot list for an edit. Produced by shot-curator / ff match shots and consumed by QA gate, NLE exporters, and the dashboard timeline editor.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project_slug", "fps", "resolution", "shots"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "project_slug": {"type": "string", "minLength": 1},
    "fps": {"type": "number", "enum": [23.976, 24, 25, 29.97, 30, 48, 50, 59.94, 60]},
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": {"type": "integer", "exclusiveMinimum": 0},
        "height": {"type": "integer", "exclusiveMinimum": 0}
      }
    },
    "song_duration_sec": {"type": "number", "exclusiveMinimum": 0},
    "fandom_quota": {
      "description": "Per-act fandom share targets. QA gate enforces within +/- tolerance.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "shots": {
      "type": "array",
      "items": {"$ref": "#/$defs/Shot"}
    },
    "rejected": {
      "description": "Candidate shots explicitly rejected — kept so the audit trail survives.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "source_timecode", "reason"],
        "properties": {
          "source_id": {"type": "string"},
          "source_timecode": {"type": "string"},
          "reason": {"type": "string"}
        }
      }
    },
    "generated_at": {"type": "string", "format": "date-time"},
    "generator": {"type": "string"}
  },
  "$defs": {
    "Shot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "act",
        "start_frame",
        "duration_frames",
        "source_id",
        "source_timecode",
        "role"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "act": {"type": "integer", "minimum": 1, "maximum": 5},
        "start_frame": {"type": "integer", "minimum": 0},
        "duration_frames": {"type": "integer", "exclusiveMinimum": 0},
        "source_id": {
          "description": "Must match an id in the catalog / source-catalog for this project.",
          "type": "string",
          "minLength": 1
        },
        "source_timecode": {
          "description": "Source-side in-point (HH:MM:SS.mmm).",
          "type": "string",
          "pattern": "^[0-9]{1,3}:[0-5][0-9]:[0-5][0-9](\\.[0-9]+)?$"
        },
        "role": {
          "type": "string",
          "enum": [
            "hero",
            "action",
            "reaction",
            "environment",
            "detail",
            "motion",
            "gaze",
            "cut-on-action",
            "establishing",
            "transition",
            "insert",
            "title"
          ]
        },
        "mood_tags": {"type": "array", "items": {"type": "string"}},
        "framing": {
          "type": "string",
          "enum": ["", "ECU", "CU", "MCU", "medium", "MS", "MWS", "wide", "WS", "EWS", "insert", "OTS", "POV"]
        },
        "motion_vector": {
          "description": "Screen-space motion direction in degrees (0 = right, 90 = down). Null for static shots.",
          "anyOf": [
            {"type": "number", "minimum": -180, "maximum": 360},
            {"type": "null"}
          ]
        },
        "eyeline": {
          "type": "string",
          "enum": ["", "left", "right", "camera", "up", "down", "mixed"]
        },
        "beat_sync": {
          "description": "Which beat/drop/downbeat this shot's start is synced to.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {"type": "string", "enum": ["beat", "downbeat", "drop", "buildup", "breakdown", "onset", "free"]},
            "index": {"type": "integer", "minimum": 0},
            "time_sec": {"type": "number", "minimum": 0}
          }
        },
        "scores": {
          "description": "Shot-curator T/F/E/B scores (each 0-5).",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "theme_fit": {"type": "number", "minimum": 0, "maximum": 5},
            "fandom_balance": {"type": "number", "minimum": 0, "maximum": 5},
            "emotion": {"type": "number", "minimum": 0, "maximum": 5},
            "beat_sync_score": {"type": "number", "minimum": 0, "maximum": 5}
          }
        },
        "transition_to_next": {
          "type": "string",
          "enum": ["hard_cut", "match_cut", "flash_cut", "whip_pan", "dip_to_black", "cross_dissolve", "speed_ramp", "flash_stack", "morph", "none"]
        },
        "safe_area_ok": {"type": "boolean"},
        "cliche_flag": {"type": "boolean"},
        "override_reason": {
          "description": "Required when cliche_flag is true — explains why the cliche is intentional.",
          "type": "string"
        },
        "reuse_index": {
          "description": "0 = first use of this source+timecode in the edit. Incremented for each reuse.",
          "type": "integer",
          "minimum": 0
        },
        "intent": {
          "description": "Intentional-reuse marker. Absent/null = default, treat as a unique shot and do not pick the same source+timecode twice.",
          "type": ["string", "null"],
          "enum": [null, "callback", "motif", "rhyme"]
        },
        "callback_of": {
          "description": "When intent=callback, the id of the earlier shot this one literally repeats. The proposer will mirror the source_id + source_timecode of the referenced shot.",
          "type": "string"
        },
        "description": {"type": "string"},
        "color_notes": {"type": "string"},
        "characters": {"type": "array", "items": {"type": "string"}},
        "fandom": {"type": "string"},
        "clip_category": {
          "description": "Phase 1.3 — taxonomy id from clip-category.schema.json. Drives slot-fit scoring.",
          "type": "string",
          "enum": [
            "establishing", "action-high", "action-mid", "reaction-quiet",
            "reaction-emotional", "dialogue-primary", "dialogue-reaction",
            "transitional", "climactic", "resolution", "texture"
          ]
        },
        "emotional_register": {
          "description": "Phase 1.3 — 8-dim emotional vector. Order matches intent.tone_vector: [grief, triumph, fear, awe, tension, release, sorrow, elation]. Each 0-1.",
          "type": "array",
          "items": {"type": "number", "minimum": 0, "maximum": 1},
          "minItems": 8,
          "maxItems": 8
        },
        "action_intensity_pct": {
          "description": "Phase 1.3 — motion magnitude 0-100, normalized against the source's typical motion baseline.",
          "type": "number", "minimum": 0, "maximum": 100
        },
        "dialogue_clarity_score": {
          "description": "Phase 1.3 — 0-100 SNR + word-confidence proxy from whisper. Null when no transcript.",
          "anyOf": [
            {"type": "number", "minimum": 0, "maximum": 100},
            {"type": "null"}
          ]
        },
        "lip_sync_confidence": {
          "description": "Phase 1.3 — mouth-region motion vs spoken-line plausibility 0-1. Null when no face / no whisper.",
          "anyOf": [
            {"type": "number", "minimum": 0, "maximum": 1},
            {"type": "null"}
          ]
        },
        "visual_style": {
          "description": "Phase 1.3 — inherited from source-profile.source_type so slot-fit can warn on cross-style cuts.",
          "type": "string",
          "enum": ["anime", "live_action", "western_animation", "3d_render", "archival", "music_video", "sports", "documentary", "mixed"]
        },
        "audio_type": {
          "description": "Phase 1.3 — what kind of audio the source-clip carries. Drives mixer's preserve-diegetic / score-strip / voice-carry decisions.",
          "type": "string",
          "enum": ["dialogue_present", "sfx_only", "music_clean", "scene_audio", "ambience", "silent"]
        },
        "energy_zone_fit": {
          "description": "Phase 1.3 — suitability for [low, mid, high] energy zones, derived from clip_category × clip-categories.energy_zone_affinity.",
          "type": "array",
          "items": {"type": "number", "minimum": 0, "maximum": 1},
          "minItems": 3, "maxItems": 3
        },
        "slot_fit_score": {
          "description": "Phase 2.2 — composite slot-fit score 0-1 stamped after the slot-fit scorer runs.",
          "type": "number", "minimum": 0, "maximum": 1
        }
      }
    }
  }
}
