{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fandomforge.dev/schemas/transcript.schema.json",
  "title": "Transcript",
  "description": "Word-level transcript produced by Whisper or parsed from SRT. One file per source.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_id", "language", "segments"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "source_id": {"type": "string", "minLength": 1},
    "language": {
      "description": "ISO 639-1 code.",
      "type": "string",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
    },
    "model": {
      "description": "Which transcription model produced this. e.g. 'whisper-large-v3', 'srt-import', 'openai-api'.",
      "type": "string"
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["start_sec", "end_sec", "text"],
        "properties": {
          "id": {"type": "integer", "minimum": 0},
          "start_sec": {"type": "number", "minimum": 0},
          "end_sec": {"type": "number", "minimum": 0},
          "text": {"type": "string"},
          "character": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "words": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["word", "start_sec", "end_sec"],
              "properties": {
                "word": {"type": "string"},
                "start_sec": {"type": "number", "minimum": 0},
                "end_sec": {"type": "number", "minimum": 0},
                "confidence": {"type": "number", "minimum": 0, "maximum": 1}
              }
            }
          }
        }
      }
    },
    "generated_at": {"type": "string", "format": "date-time"}
  }
}
