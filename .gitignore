# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/

# Next.js
web/.next/
web/out/
web/*.tsbuildinfo
web/next-env.d.ts

# Playwright
web/playwright-report/
web/test-results/
