# Python
tools/.venv/
tools/**/__pycache__/
tools/**/*.pyc
tools/.pytest_cache/
tools/.mypy_cache/
tools/.ruff_cache/
tools/*.egg-info/
tools/build/
tools/dist/

# OS
.DS_Store
Thumbs.db

# Env / secrets — NEVER commit these
.env
.env.local
.env.*.local
web/.env.local
github.rtf
github.txt
claude.rtf
claude.txt
anthropic.rtf
anthropic.txt
*.rtf
*.token
*.pem
**/secrets/
**/*secret*
**/*.credentials
.netrc
.gh-token

# Editor
.vscode/
.idea/
*.swp

# FandomForge runtime
web/.runs/
projects/*/derived/
projects/*/exports/
projects/*/raw/*.mp4
projects/*/raw/*.mov
projects/*/raw/*.mkv
projects/*/raw/*.webm
projects/*/raw/*.mp3
projects/*/raw/*.wav
projects/*/raw/*.m4a
.fandomforge-cache/

# Test fixtures — the manifest is committed, the downloaded media is not.
tools/tests/fixtures/media/

# Reference corpus — downloaded playlist videos are not committed.
# The priors JSON is committed (that's how the planner learns); the MP4s aren't.
references/**/*.mp4
references/**/*.mkv
references/**/*.webm
references/.cache/
references/**/.transcripts/

# Other scraps and local-only dirs
.history/
action-legends/
projects/
.claude/scheduled_tasks.lock

# Runtime cache (web server work dir, logs, auto-generated priors, training journal)
.cache/
tools/.cache/

# Forensic products per-bucket — the bucket-reports are committed, raw forensics aren't
references/*/forensic/*.forensic.json
references/*/forensic/*.mp4
references/*/forensic/*.wav
references/*/forensic/*.song.wav
