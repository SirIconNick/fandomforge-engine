# FandomForge web — environment variables
#
# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Required for the expert chat feature (/experts/chat/*). Without this the chat
# route returns a 500 with a clear error, but the rest of the app still works.
# Get a key at https://console.anthropic.com/.
ANTHROPIC_API_KEY=sk-ant-

# Optional. Override the Claude model used for expert chat. Defaults to the
# current recommended Claude 4 Sonnet model if not set.
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Optional. Absolute path to the `ff` CLI binary for pipeline tool use
# (/api/pipeline/step). Defaults to ../tools/.venv/bin/ff relative to this
# web/ directory.
# FF_BINARY=/Users/you/Projects/fandomforge-engine/tools/.venv/bin/ff
